rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── 헬퍼 함수 ────────────────────────────────────────────────
    // 로그인 여부 확인
    function isSignedIn() {
      return request.auth != null;
    }

    // Custom Claims 기반 역할 확인 (Cloud Function에서 setCustomUserClaims 필요)
    function getRole() {
      return request.auth.token.role;
    }

    function isStudent() {
      return getRole() == 'STUDENT';
    }

    function isInstructor() {
      return getRole() == 'INSTRUCTOR';
    }

    function isSuperAdmin() {
      return getRole() == 'SUPER_ADMIN';
    }

    // STUDENT가 아닌 사용자만 관리 기능 접근 가능
    function hasAdminAccess() {
      return isInstructor() || isSuperAdmin();
    }

    // Firestore에서 현재 사용자의 승인 상태 확인
    function isApproved() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid))
        .data.status == 'approved';
    }

    // 문서 소유자 여부
    function isOwner(uid) {
      return request.auth.uid == uid;
    }

    // ── users 컬렉션 ──────────────────────────────────────────────
    match /users/{userId} {
      // 본인 문서 읽기 허용
      allow get: if isSignedIn() && isOwner(userId);
      // 교사·관리자만 목록 조회
      allow list: if isSignedIn() && hasAdminAccess();
      // SUPER_ADMIN만 생성·수정·삭제 (Cloud Function Admin SDK는 규칙 적용 제외)
      allow create, update, delete: if isSignedIn() && isSuperAdmin();
    }

    // ── courses 컬렉션 ────────────────────────────────────────────
    match /courses/{courseId} {
      allow read: if isSignedIn() && isApproved();
      allow write: if isSignedIn() && isSuperAdmin();
    }

    // ── notices 컬렉션 ────────────────────────────────────────────
    match /notices/{noticeId} {
      allow read: if isSignedIn() && isApproved();
      // 교사·관리자만 등록·수정, 삭제는 관리자만
      allow create, update: if isSignedIn() && hasAdminAccess() && isApproved();
      allow delete: if false;
    }

    // ── jobs 컬렉션 ──────────────────────────────────────────────
    match /jobs/{jobId} {
      allow read: if isSignedIn() && isApproved();
      allow create: if isSignedIn() && hasAdminAccess() && isApproved();
      allow delete: if false;
      // 교사·관리자: 전체 수정 / 승인된 사용자: view_count 단독 증가 허용
      allow update: if isSignedIn() && isApproved() && (
        hasAdminAccess() ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['view_count'])
      );
    }

    // ── job_applications 컬렉션 ──────────────────────────────────
    match /job_applications/{appId} {
      // 본인 지원 내역 또는 교사·관리자만 조회
      allow read: if isSignedIn() && (
        isOwner(resource.data.applicant_id) || hasAdminAccess()
      );
      // 학생만 본인 명의로 지원 가능 (승인된 계정 필수)
      allow create: if isSignedIn()
        && isStudent()
        && isApproved()
        && isOwner(request.resource.data.applicant_id);
      // 학생: 본인 신청 취소(status 변경) / 교사·관리자: 전체 상태 변경
      allow update: if isSignedIn() && (
        (isStudent() && isApproved() && isOwner(resource.data.applicant_id)) ||
        hasAdminAccess()
      );
      // 물리 삭제 금지 — 취소는 status 필드 update로 처리
      allow delete: if false;
    }

    // ── job_comments 컬렉션 ──────────────────────────────────────
    match /job_comments/{commentId} {
      allow read: if isSignedIn() && isApproved();
      allow create: if isSignedIn() && isApproved();
      // 작성자 본인 또는 관리자만 수정 (Soft Delete: content 필드 교체)
      allow update: if isSignedIn() && (
        isOwner(resource.data.author_id) || isSuperAdmin()
      );
      allow delete: if false;
    }

    // ── qna 컬렉션 ───────────────────────────────────────────────
    match /qna/{qnaId} {
      allow read: if isSignedIn() && isApproved();
      allow create: if isSignedIn() && isApproved();
      // 작성자 본인 또는 관리자만 수정·삭제
      allow update, delete: if isSignedIn() && (
        isOwner(resource.data.author_id) || isSuperAdmin()
      );
    }

    // ── delete_requests 컬렉션 (Cloud Function 트리거 전용) ───────
    match /delete_requests/{reqId} {
      // 클라이언트 직접 접근 차단 — Admin SDK만 처리
      allow read, update, delete: if false;
      allow create: if isSignedIn() && isSuperAdmin();
    }
  }
}
